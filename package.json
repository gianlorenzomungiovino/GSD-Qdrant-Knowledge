{
  "name": "gsd-qdrant-cli",
  "version": "1.0.7",
  "description": "CLI per setup automatico GSD + Qdrant in qualsiasi progetto Node.js",
  "main": "scripts/cli.js",
  "bin": {
    "gsd-qdrant": "scripts/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sync-knowledge": "node scripts/sync-knowledge.js"
  },
  "keywords": [
    "gsd",
    "qdrant",
    "knowledge-base",
    "mcp",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gianlorenzomungiovino/GSD-Qdrant-Knowledge.git"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "@xenova/transformers": "^2.17.2"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "scripts/cli.js",
    "scripts/sync-knowledge.js",
    "scripts/setup-from-templates.js",
    "scripts/gsd-qdrant-template.js",
    "README.md",
    "GSD-QDRANT-SETUP.md",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "vitest": "^4.1.2"
  }
}
