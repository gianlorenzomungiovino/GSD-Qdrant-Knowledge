      "content": "import \"./TeamMember.css\";\n\n/**\n * TeamMemberImage - Card immagine del membro del team\n * @param {Object} props - Props del membro\n * @param {Object} props.member - Oggetto membro con image e name\n */\nfunction TeamMemberImage({ member }) {\n  const getImageSrc = () => {\n    if (!member.image) {\n      return \"/assets/team/default.jpg\";\n    }\n    return member.image;\n  };\n\n  const getImageAlt = () => {\n    if (!member.name) {\n      return \"Membro del team\";\n    }\n    return `Ritratto di ${member.name}`;\n  };\n\n  return (\n    <div className=\"team-member-image\">\n      <div className=\"team-member-image__wrapper\">\n        <img\n          src={getImageSrc()}\n          alt={getImageAlt()}\n          className=\"team-member-image__img\"\n          loading=\"lazy\"\n        />\n      </div>\n      <div className=\"team-member-image__content\">\n        <span className=\"team-member-image__role\">{member.role}</span>\n        <h3 className=\"team-member-image__name\">{member.name}</h3>\n      </div>\n    </div>\n  );\n}\n\n/**\n * TeamMemberContent - Card contenuto/testo del membro del team\n * @param {Object} props - Props del membro\n * @param {Object} props.member - Oggetto membro con role, name, description\n */\nfunction TeamMemberContent({ member }) {\n  return (\n    <div className=\"team-member-content\">\n      <span className=\"team-member-content__role\">{member.role}</span>\n      <h3 className=\"team-member-content__name\">{member.name}</h3>\n      <p className=\"team-member-content__description\">{member.description}</p>\n    </div>\n  );\n}\n\nexport { TeamMemberImage, TeamMemberContent };\n",
